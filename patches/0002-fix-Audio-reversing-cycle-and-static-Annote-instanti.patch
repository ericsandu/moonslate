From 2475d59052eb578dc686964f851e36b1588e058b Mon Sep 17 00:00:00 2001
From: Eric Sandu <eric_andrei.sandu@stud.acs.upb.ro>
Date: Tue, 21 Jul 2026 22:05:12 +0300
Subject: [PATCH 2/2] fix: Audio reversing cycle and static Annote
 instantiation

---
 core/cpp-annote/src/cpp-annote.cpp |  8 +++++++-
 core/moonshine-c-api.cpp           | 11 +++++++++--
 2 files changed, 16 insertions(+), 3 deletions(-)

diff --git a/core/cpp-annote/src/cpp-annote.cpp b/core/cpp-annote/src/cpp-annote.cpp
index 20d57aa..cf12162 100644
--- a/core/cpp-annote/src/cpp-annote.cpp
+++ b/core/cpp-annote/src/cpp-annote.cpp
@@ -984,7 +984,13 @@ struct CppAnnote::Impl {
     std::vector<float> chunk(chunk_size, 0.0f);
     if (audio_length > 0) {
         for(int i = 0; i < chunk_size; i++) {
-            chunk[i] = audio_data[i % audio_length];
+            int cycle = i / audio_length;
+            int idx = i % audio_length;
+            if (cycle % 2 == 1) {
+                chunk[i] = audio_data[audio_length - 1 - idx];
+            } else {
+                chunk[i] = audio_data[idx];
+            }
         }
     }
     
diff --git a/core/moonshine-c-api.cpp b/core/moonshine-c-api.cpp
index cb2e9d6..2a19ec0 100644
--- a/core/moonshine-c-api.cpp
+++ b/core/moonshine-c-api.cpp
@@ -717,8 +717,15 @@ void moonshine_free_intent_embedding(float *embedding) { std::free(embedding); }
 int32_t moonshine_extract_speaker_embedding(const float *audio_data, uint64_t audio_length, int32_t sample_rate, float **out_embedding, uint64_t *out_embedding_size) {
     if (!audio_data || !out_embedding || !out_embedding_size) return MOONSHINE_ERROR_INVALID_ARGUMENT;
     try {
-        cppannote::CppAnnote engine;
-        std::vector<float> embed = engine.extract_embedding(audio_data, audio_length, sample_rate);
+        static std::mutex g_annote_mutex;
+        static std::unique_ptr<cppannote::CppAnnote> g_annote;
+        
+        std::lock_guard<std::mutex> lock(g_annote_mutex);
+        if (!g_annote) {
+            g_annote = std::make_unique<cppannote::CppAnnote>();
+        }
+        
+        std::vector<float> embed = g_annote->extract_embedding(audio_data, audio_length, sample_rate);
         *out_embedding_size = embed.size();
         *out_embedding = static_cast<float*>(std::malloc(embed.size() * sizeof(float)));
         std::copy(embed.begin(), embed.end(), *out_embedding);
-- 
