Subject: [PATCH 1/2] Expose raw acoustic fingerprint extraction & fix
 zero-padding InstanceNorm corruption

---
 core/cpp-annote/src/cpp-annote.cpp | 49 ++++++++++++++++++++++++++++++
 core/cpp-annote/src/cpp-annote.h   |  4 +++
 core/moonshine-c-api.cpp           | 17 +++++++++++
 core/moonshine-c-api.h             | 10 ++++++
 4 files changed, 80 insertions(+)

diff --git a/core/cpp-annote/src/cpp-annote.cpp b/core/cpp-annote/src/cpp-annote.cpp
index b7a8805..20d57aa 100644
--- a/core/cpp-annote/src/cpp-annote.cpp
+++ b/core/cpp-annote/src/cpp-annote.cpp
@@ -969,6 +969,49 @@ struct CppAnnote::Impl {
     }
     return r;
   }
+
+  std::vector<float> extract_embedding(const float *audio_data, uint64_t audio_length, int32_t sample_rate) {
+    std::vector<float> resampled;
+    int sr_model = engine.segmentation_model_sample_rate();
+    if (sample_rate != sr_model) {
+      std::vector<float> in(audio_data, audio_data + audio_length);
+      resampled = wav_pcm::linear_resample(in, sample_rate, sr_model);
+      audio_data = resampled.data();
+      audio_length = resampled.size();
+    }
+    
+    int chunk_size = engine.segmentation_chunk_num_samples();
+    std::vector<float> chunk(chunk_size, 0.0f);
+    if (audio_length > 0) {
+        for(int i = 0; i < chunk_size; i++) {
+            chunk[i] = audio_data[i % audio_length];
+        }
+    }
+    
+    std::vector<float> seg = engine.run_segmentation_ort_single(chunk.data());
+    std::vector<float> emb_all = engine.run_embedding_ort_single(chunk.data(), seg.data());
+    
+    int K = engine.seg_classes();
+    int F = engine.seg_frames_per_chunk();
+    int dim = engine.embedding_dimension();
+    
+    int best_sp = 0;
+    float max_activity = -1.0f;
+    for (int sp = 0; sp < K; ++sp) {
+        float activity = 0.0f;
+        for (int f = 0; f < F; ++f) {
+            activity += seg[f * K + sp];
+        }
+        if (activity > max_activity) {
+            max_activity = activity;
+            best_sp = sp;
+        }
+    }
+    
+    std::vector<float> single_emb(dim);
+    std::copy(emb_all.begin() + best_sp * dim, emb_all.begin() + (best_sp + 1) * dim, single_emb.begin());
+    return single_emb;
+  }
 };
 
 CppAnnote::CppAnnote() : impl_(std::make_unique<Impl>()) {}
@@ -1035,4 +1078,10 @@ DiarizationResults CppAnnote::diarize_stream(int32_t stream_id) {
   return Impl::to_results(snap);
 }
 
+std::vector<float> CppAnnote::extract_embedding(const float *audio_data,
+                                                uint64_t audio_length,
+                                                int32_t sample_rate) {
+  return impl_->extract_embedding(audio_data, audio_length, sample_rate);
+}
+
 }  // namespace cppannote
