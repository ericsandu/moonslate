diff --git a/core/moonshine-c-api.cpp b/core/moonshine-c-api.cpp
index 1775594..cb2e9d6 100644
--- a/core/moonshine-c-api.cpp
+++ b/core/moonshine-c-api.cpp
@@ -64,6 +64,7 @@ SOFTWARE.
 #include "ort-utils.h"
 #include "string-utils.h"
 #include "transcriber.h"
+#include "cpp-annote/src/cpp-annote.h"
 
 // Defined as a macro to ensure we get meaningful line numbers in the error
 // message.
@@ -713,6 +714,22 @@ int32_t moonshine_calculate_intent_embedding(int32_t intent_recognizer_handle,
 
 void moonshine_free_intent_embedding(float *embedding) { std::free(embedding); }
 
+int32_t moonshine_extract_speaker_embedding(const float *audio_data, uint64_t audio_length, int32_t sample_rate, float **out_embedding, uint64_t *out_embedding_size) {
+    if (!audio_data || !out_embedding || !out_embedding_size) return MOONSHINE_ERROR_INVALID_ARGUMENT;
+    try {
+        cppannote::CppAnnote engine;
+        std::vector<float> embed = engine.extract_embedding(audio_data, audio_length, sample_rate);
+        *out_embedding_size = embed.size();
+        *out_embedding = static_cast<float*>(std::malloc(embed.size() * sizeof(float)));
+        std::copy(embed.begin(), embed.end(), *out_embedding);
+        return MOONSHINE_ERROR_NONE;
+    } catch (...) {
+        return MOONSHINE_ERROR_UNKNOWN;
+    }
+}
+
+void moonshine_free_speaker_embedding(float *embedding) { std::free(embedding); }
+
 int32_t moonshine_calculate_embedding_distance(int32_t intent_recognizer_handle,
                                                const float *embedding_a,
                                                const float *embedding_b,
